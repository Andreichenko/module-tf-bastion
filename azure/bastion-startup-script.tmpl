#!/bin/bash

# Output information about what this script is doing.
function info {
  echo "startup-script: $@"
}

# Azure startup scripts are run on boot.
info Determining whether this script has been run before. . .
if [ -r /metadata_startup_script-has_run ] ; then
  info This script has been run, as the /metadata_startup_script-has_run file exists.
  info Exiting...
  exit 0
fi
touch /metadata_startup_script-has_run

# UCF options to prevent interactive menus
export UCF_FORCE_CONFFOLD=yes
ucf --purge /boot/grub/menu.lst
export DEBIAN_FRONTEND=noninteractive

info Updating packages. . .
apt-get -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold" update

info Triggering a job using at, to sleep then run apt-get upgrade...
echo "sleep 120 ; apt-get -y -o Dpkg::Options::=\"--force-confdef\" -o Dpkg::Options::=\"--force-confold\" upgrade" | at now

info Installing packages needed on the bastion...
apt-get -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold" install python unattended-upgrades curl apt-transport-https lsb-release gnupg

info Installing Azure CLI...
curl -sL https://aka.ms/InstallAzureCLIDeb | bash

info Log in to Azure using Managed Identity...
az login --identity

storage_account_name="${infrastructure_storage_account_name}"
container_name="${infrastructure_storage_container_name}"

info The infra storage account is: $storage_account_name and the container is: $container_name

info Looking for SSHd host keys to copy from Azure Blob Storage. . .
az storage blob exists --auth-mode login --account-name "$storage_account_name" --container-name "$container_name" --name "sshd/ssh_host_rsa_key" --query exists -o tsv | grep -i "true" >/dev/null
if [ $? -eq 0 ] ; then
  info Syncing host keys from Azure Blob Storage
  for key_type in rsa dsa ecdsa ed25519; do
    az storage blob download --auth-mode login --account-name "$storage_account_name" --container-name "$container_name" --name "sshd/ssh_host_${key_type}_key" --file "/etc/ssh/ssh_host_${key_type}_key" 2>/dev/null
    az storage blob download --auth-mode login --account-name "$storage_account_name" --container-name "$container_name" --name "sshd/ssh_host_${key_type}_key.pub" --file "/etc/ssh/ssh_host_${key_type}_key.pub" 2>/dev/null
  done
  chmod go= /etc/ssh/ssh_host_*_key
  info Restarting sshd to use new host keys
  systemctl restart ssh
else
  info Copying host keys to Azure Blob Storage, this must be the first ever bastion instance...
  for n in /etc/ssh/ssh_host_*; do
    blob_name="sshd/$(basename $n)"
    az storage blob upload --auth-mode login --account-name "$storage_account_name" --container-name "$container_name" --name "$blob_name" --file "$n" --overwrite true
  done
fi

info Configuring unattended upgrades in /etc/apt/apt.conf.d/50unattended-upgrades
cat <<EOF >>/etc/apt/apt.conf.d/50unattended-upgrades
// Options added by startup-script and Terraform:
Unattended-Upgrade::Automatic-Reboot "true";
Unattended-Upgrade::Automatic-Reboot-Time "${unattended_upgrade_reboot_time}";
Unattended-Upgrade::MailOnlyOnError "true";
Unattended-Upgrade::Mail "${unattended_upgrade_email_recipient}";
${unattended_upgrade_additional_configs}
EOF

# Execute optional additional setup script (before users are created)
if [ ! -z "${additional_setup_script}" ] ; then
  info "Executing additional_setup_script. . ."
  ${additional_setup_script}
  info "Finished executing additional_setup_script. . ."
fi

# Add optional additional users and authorized_keys
${additional_user_templates}

# Run the additional-external-users script from Azure Blob Storage if configured
if [ "${additional_external_users_script_md5}" != "" ] ; then
  info Running the additional-external-users script
  az storage blob download --auth-mode login --account-name "$storage_account_name" --container-name "$container_name" --name "additional-external-users" --file "/usr/local/bin/additional-external-users"
  chmod +x /usr/local/bin/additional-external-users

  info Installing the additional-external-users systemd service
  cat <<EOF >/etc/systemd/system/additional-external-users.service
[Unit]
Description=Add all defined additional external users to the bastion
After=network.target

[Service]
ExecStart=/usr/local/bin/additional-external-users
Type=oneshot
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF
  systemctl daemon-reload
  systemctl enable additional-external-users
  systemctl start additional-external-users
fi

# Remove root/sudo access from default ubuntu user if requested
rra=$(echo ${remove_root_access} | tr '[:upper:]' '[:lower:]')
if [ "$rra" == "true" ] || [ "$rra" == "yes" ] || [ "$rra" == "1" ] ; then
  info Removing root access from the ubuntu user as remove_root_access is set to $rra
  rm -f /etc/sudoers.d/90-cloud-init-users
  # Azure standard user could be 'ubuntu' or 'azureuser'
  deluser ubuntu sudo 2>/dev/null
  deluser azureuser sudo 2>/dev/null
else
  info Retaining root access as remove_root_access is set to "$rra"
fi

info Rebooting, if required by any kernel updates earlier
if [ -f /var/run/reboot-required ] ; then
  echo Reboot is required, doing that now...
  shutdown -r now
fi
